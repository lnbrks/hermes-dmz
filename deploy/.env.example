# Copy to deploy/.env and fill in. deploy/.env is gitignored — never commit it.
# docker compose reads this file automatically for ${VAR} substitution.

# ── Model (OpenRouter) ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-REPLACE_ME

# ── Telegram (delivery + control) ───────────────────────────────────────────
# Bot token from @BotFather. Allowed users = your numeric Telegram user id(s).
TELEGRAM_BOT_TOKEN=123456:REPLACE_ME
TELEGRAM_ALLOWED_USERS=123456789
# Chat id the agent posts run summaries to (your DM with the bot, or a group).
TELEGRAM_CHAT_ID=123456789

# ── Webhook trigger (host systemd → hermes) ─────────────────────────────────
# Shared HMAC secret. Generate with: openssl rand -hex 32
WEBHOOK_SECRET=REPLACE_ME_openssl_rand_hex_32

# ── Sandbox dummy credentials (shared secret: sandbox ↔ gateway) ────────────
# The sandbox sends these dummies; the gateway verifies them and swaps in the
# real secret. Defaults below are fine; for stronger defense set them to random
# values (must match on both sides — compose handles that automatically).
#   SANDBOX_GOOGLE_TOKEN:    any string (e.g. openssl rand -hex 24)
#   SANDBOX_OPENROUTER_KEY:  any string
#   SANDBOX_TELEGRAM_TOKEN:  MUST be <digits>:<word> with NO slashes (it sits in
#                            the URL path) — e.g. 111111:$(openssl rand -hex 24)
SANDBOX_GOOGLE_TOKEN=dummy-sandbox-token
SANDBOX_OPENROUTER_KEY=dummy-openrouter-key
SANDBOX_TELEGRAM_TOKEN=111111:DUMMYtelegramTOKEN0000000000000000

# ── gws binary on the host (bind-mounted read-only into the hermes container) ─
# Path to your gws CLI. Default assumes the cargo install location.
GWS_BIN=/home/ilana/.cargo/bin/gws

# NOTE: the real Google credential is NOT here. It lives only on the gateway
# side, in deploy/state/secrets/gws-creds.json (see README "Credentials").
